rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role helpers
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isDonor() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'Donor';
    }

    function isReceiver() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'Receiver';
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isEmailVerified() && request.auth.uid == userId 
        && incoming().role in ['Donor', 'Receiver']
        && incoming().full_name is string && incoming().full_name.size() <= 100;
      allow update: if isOwner(userId) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['full_name', 'phone', 'organization_name'])
        && incoming().full_name is string && incoming().full_name.size() <= 100;
    }

    // --- Food Posts ---
    function isValidFoodPost(data) {
      return data.donorId is string && data.foodType is string && data.foodType.size() <= 200
        && data.quantity is int && data.quantity > 0
        && data.pickupAddress is string && data.pickupAddress.size() <= 500
        && data.status in ['pending', 'claimed', 'delivered', 'expired']
        && (data.notes == null || (data.notes is string && data.notes.size() <= 1000));
    }

    match /foodPosts/{postId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      
      allow create: if isDonor() && isOwner(incoming().donorId) 
        && isValidFoodPost(incoming())
        && incoming().status == 'pending'
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isSignedIn() && (
        // Donor can update their own post if it's not delivered/expired
        (isOwner(existing().donorId) && existing().status in ['pending', 'claimed'] 
          && isValidFoodPost(incoming())
          && incoming().donorId == existing().donorId
          && incoming().updatedAt == request.time
          && (
            // Just updating details if pending
            (existing().status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['foodType', 'quantity', 'pickupAddress', 'notes', 'expiryTime', 'updatedAt']))
            ||
            // Cancelling/Expiring
            (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status in ['pending', 'expired'])
          )
        )
        ||
        // Receiver can claim a pending post
        (isReceiver() && existing().status == 'pending' && incoming().status == 'claimed'
          && incoming().claimedBy == request.auth.uid
          && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'claimedBy', 'updatedAt'])
          && incoming().updatedAt == request.time
        )
        ||
        // Receiver can mark as delivered if they claimed it
        (isOwner(existing().claimedBy) && existing().status == 'claimed' && incoming().status == 'delivered'
          && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
          && incoming().updatedAt == request.time
        )
      );
    }

    // --- Claims ---
    match /claims/{claimId} {
      allow list: if isSignedIn();
      allow create: if isReceiver() && isOwner(incoming().receiverId)
        && exists(/databases/$(database)/documents/foodPosts/$(incoming().foodPostId))
        && incoming().createdAt == request.time;
    }
  }
}
